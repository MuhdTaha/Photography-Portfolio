---
// src/components/Lightbox.astro
---
<div id="lightbox" class="fixed inset-0 z-100 hidden opacity-0 scale-[0.99] bg-black/95 backdrop-blur-sm items-center justify-center cursor-default select-none transition-[opacity,transform] duration-300 ease-out">
  
  <div id="lightbox-loader" class="absolute inset-0 grid place-items-center" hidden>
    <div class="h-10 w-10 animate-spin rounded-full border-2 border-brand-gold/20 border-t-brand-gold"></div>
  </div>

  <button id="close-lightbox" class="absolute top-6 right-6 z-110 cursor-pointer p-4 text-white/50 transition-colors hover:text-brand-gold">
    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
  </button>

  <button id="prev-photo" class="group absolute bottom-0 left-0 top-0 z-105 flex w-[15%] cursor-pointer items-center justify-center to-transparent text-white/20 transition-all hover:bg-linear-to-r hover:from-black/40 hover:text-brand-gold">
    <svg class="group-hover:-translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  
  <button id="next-photo" class="group absolute bottom-0 right-0 top-0 z-105 flex w-[15%] cursor-pointer items-center justify-center to-transparent text-white/20 transition-all hover:bg-linear-to-l hover:from-black/40 hover:text-brand-gold">
    <svg class="group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>

  <div class="relative flex h-full max-h-dvh w-full max-w-[100vw] flex-col items-center justify-center p-4 md:p-16">
    <div class="relative flex items-center justify-center w-full h-full pointer-events-none">
      <img 
        id="lightbox-img" 
        src="" 
        alt="" 
        draggable="false"
        class="z-110 pointer-events-auto max-h-full max-w-full select-none object-contain shadow-2xl transition-opacity duration-300 w-auto h-auto"
      />
    </div>
    <p id="lightbox-caption" class="pointer-events-none absolute bottom-6 left-1/2 w-full max-w-3xl -translate-x-1/2 px-4 text-center font-display text-[10px] uppercase tracking-[0.4em] text-white/50"></p>
  </div>
</div>

<script>
  type CleanupFn = () => void;

  declare global {
    interface Window {
      __lightboxCleanup?: CleanupFn;
      __lightboxPageLoadBound?: boolean;
    }
  }

  function initLightbox() {
    window.__lightboxCleanup?.();

    const lightbox = document.getElementById('lightbox');
    const loader = document.getElementById('lightbox-loader');
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('close-lightbox');
    const prevBtn = document.getElementById('prev-photo');
    const nextBtn = document.getElementById('next-photo');
    const isTouchDevice = window.matchMedia('(hover: none) and (pointer: coarse)').matches;

    let currentImages: string[] = [];
    let currentCaptions: string[] = [];
    let currentIndex = 0;
    let loaderTimeout: ReturnType<typeof setTimeout> | undefined;
    let closeTimeout: ReturnType<typeof setTimeout> | undefined;
    let touchStartX = 0;
    let touchEndX = 0;
    let photoHoverObserver: IntersectionObserver | undefined;
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const initPhotoHoverReveal = () => {
      if (!isTouchDevice) return;

      const photoCards = Array.from(document.querySelectorAll<HTMLElement>('[data-photo-card]'));
      if (!photoCards.length) return;

      photoHoverObserver = new IntersectionObserver((entries) => {
        for (const entry of entries) {
          entry.target.setAttribute('data-in-view', entry.isIntersecting ? 'true' : 'false');
        }
      }, {
        threshold: [0.35, 0.5, 0.75],
        rootMargin: '0px 0px -10% 0px',
      });

      for (const card of photoCards) {
        card.setAttribute('data-in-view', 'false');
        photoHoverObserver.observe(card);
      }
    };

    const preloadNextImage = () => {
      if (!currentImages.length) return;
      const nextIndex = (currentIndex + 1) % currentImages.length;
      const img = new Image();
      img.src = currentImages[nextIndex];
    };

    const updateLightbox = (direction = 0) => {
      if (!lightboxImg || !currentImages.length) return;

      if (loaderTimeout) clearTimeout(loaderTimeout);
      loaderTimeout = setTimeout(() => {
        if (loader) loader.hidden = false;
      }, 300);

      const applyImage = () => {
        lightboxImg.src = currentImages[currentIndex];
        lightboxImg.alt = currentCaptions[currentIndex];
      };

      if (!prefersReducedMotion && lightboxImg.src && direction !== 0) {
        lightboxImg.animate(
          [
            { opacity: 1, transform: 'translateX(0px)' },
            { opacity: 0, transform: `translateX(${direction * 22}px)` }
          ],
          { duration: 180, easing: 'ease-in', fill: 'forwards' }
        ).onfinish = applyImage;
      } else {
        lightboxImg.style.opacity = '0';
        applyImage();
      }

      if (lightboxCaption) {
        lightboxCaption.textContent = currentCaptions[currentIndex];
      }

      lightboxImg.onload = () => {
        if (loaderTimeout) clearTimeout(loaderTimeout);
        if (loader) loader.hidden = true;

        if (!prefersReducedMotion) {
          const fromX = direction === 0 ? 0 : direction * -22;
          lightboxImg.animate(
            [
              { opacity: 0, transform: `translateX(${fromX}px)` },
              { opacity: 1, transform: 'translateX(0px)' }
            ],
            { duration: 260, easing: 'ease-out', fill: 'forwards' }
          );
        } else {
          lightboxImg.style.opacity = '1';
          lightboxImg.style.transform = 'translateX(0px)';
        }

        preloadNextImage();
      };
    };

    const close = () => {
      if (!lightbox) return;
      if (closeTimeout) clearTimeout(closeTimeout);

      lightbox.classList.remove('opacity-100', 'scale-100');
      lightbox.classList.add('opacity-0', 'scale-[0.99]');

      closeTimeout = setTimeout(() => {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
      }, prefersReducedMotion ? 0 : 260);

      document.body.style.overflow = 'auto';
      if (loaderTimeout) clearTimeout(loaderTimeout);
      if (loader) loader.hidden = true;
    };

    const navigateNext = () => {
      currentIndex = (currentIndex + 1) % currentImages.length;
      updateLightbox(-1);
    };

    const navigatePrev = () => {
      currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
      updateLightbox(1);
    };

    const onDocumentClick = (e: MouseEvent) => {
      if (!(e.target instanceof Element)) return;

      const photoTrigger = e.target.closest('.photo-trigger[data-full-url]');
      if (!photoTrigger) return;

      const allPhotos = Array.from(document.querySelectorAll('.photo-trigger[data-full-url]'));
      currentImages = allPhotos.map((p) => p.getAttribute('data-full-url') || '');
      currentCaptions = allPhotos.map((p) => p.getAttribute('data-title') || '');
      currentIndex = allPhotos.indexOf(photoTrigger);

      if (!lightbox) return;

      if (closeTimeout) clearTimeout(closeTimeout);
      updateLightbox(0);
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');

      requestAnimationFrame(() => {
        lightbox.classList.remove('opacity-0', 'scale-[0.99]');
        lightbox.classList.add('opacity-100', 'scale-100');
      });

      document.body.style.overflow = 'hidden';
    };

    const onLightboxClick = (e: MouseEvent) => {
      if (e.target === lightboxImg) return;

      const isController = (e.target as HTMLElement).closest('button');
      if (e.target !== lightboxImg && !isController) {
        close();
      }
    };

    const onNextClick = (e: MouseEvent) => {
      e.stopPropagation();
      navigateNext();
    };

    const onPrevClick = (e: MouseEvent) => {
      e.stopPropagation();
      navigatePrev();
    };

    const onTouchStart = (e: TouchEvent) => {
      touchStartX = e.changedTouches[0].screenX;
    };

    const onTouchEnd = (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      const swipeDistance = touchEndX - touchStartX;
      const threshold = 50;

      if (swipeDistance < -threshold) navigateNext();
      else if (swipeDistance > threshold) navigatePrev();
    };

    const onKeydown = (e: KeyboardEvent) => {
      if (lightbox?.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowRight') navigateNext();
      if (e.key === 'ArrowLeft') navigatePrev();
    };

    document.addEventListener('click', onDocumentClick);
    document.addEventListener('keydown', onKeydown);
    closeBtn?.addEventListener('click', close);
    lightbox?.addEventListener('click', onLightboxClick);
    nextBtn?.addEventListener('click', onNextClick);
    prevBtn?.addEventListener('click', onPrevClick);
    lightbox?.addEventListener('touchstart', onTouchStart, { passive: true });
    lightbox?.addEventListener('touchend', onTouchEnd, { passive: true });

    initPhotoHoverReveal();

    window.__lightboxCleanup = () => {
      document.removeEventListener('click', onDocumentClick);
      document.removeEventListener('keydown', onKeydown);
      closeBtn?.removeEventListener('click', close);
      lightbox?.removeEventListener('click', onLightboxClick);
      nextBtn?.removeEventListener('click', onNextClick);
      prevBtn?.removeEventListener('click', onPrevClick);
      lightbox?.removeEventListener('touchstart', onTouchStart);
      lightbox?.removeEventListener('touchend', onTouchEnd);
      photoHoverObserver?.disconnect();
      if (closeTimeout) clearTimeout(closeTimeout);
      if (loader) loader.hidden = true;
    };
  }

  if (!window.__lightboxPageLoadBound) {
    document.addEventListener('astro:page-load', initLightbox);
    window.__lightboxPageLoadBound = true;
  }

  initLightbox();
</script>