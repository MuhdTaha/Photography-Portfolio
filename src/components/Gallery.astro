---
// src/components/Gallery.astro

import { client } from '../lib/sanity';
import { ALL_PHOTOS_QUERY } from '../utils/queries';
const photos = await client.fetch(ALL_PHOTOS_QUERY);
---

<section class="bg-obsidian px-4 py-20">
  <div class="mx-auto max-w-7xl">
    <div class="columns-1 gap-4 space-y-4 sm:columns-2 lg:columns-3">
      {photos.map((photo) => (
        <div class="group relative cursor-crosshair overflow-hidden rounded-sm bg-card-dark transition-all duration-700 hover:ring-1 hover:ring-brand-gold/50">
          <img
            src={`https://res.cloudinary.com/${import.meta.env.PUBLIC_CLOUDINARY_CLOUD_NAME}/image/upload/f_auto,q_auto,w_800/${photo.publicId}`}
            alt={photo.alt}
            class="w-full transition-transform duration-1000 group-hover:scale-110 group-hover:opacity-60"
          />
          
          <div class="absolute inset-0 flex flex-col justify-end p-6 opacity-0 transition-opacity duration-500 group-hover:opacity-100">
            <span class="text-[10px] font-bold tracking-widest text-brand-gold uppercase mb-1">
              {photo.category}
            </span>
            <h3 class="font-display text-xl font-bold text-white uppercase">
              {photo.title}
            </h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>