---
// src/components/HomeBands.astro
// Dynamic horizontal bands — the original homepage category layout

import { homeCategories, type HomeCategorySlug } from '../data/homeCategories';
import { getImageUrl, getResponsiveImage } from '../utils/imageUrl';
import type { SanityImageSource } from '../utils/imageUrl';

type GalleryPhoto = {
  image: SanityImageSource;
  title: string;
  alt?: string;
  category?: string;
};

interface Props {
  photosByCategory: Record<HomeCategorySlug, GalleryPhoto[]>;
}

const { photosByCategory } = Astro.props;

const getGridImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [640, 960, 1100, 1400, 1800],
  sizes: '(max-width: 1024px) 50vw, 25vw',
  fit: 'max',
});

const getFullImageUrl = (image: SanityImageSource) => getImageUrl(image, { width: 2000, fit: 'max', quality: 85, format: 'auto' });
---

<div class="flex w-full flex-col gap-3 pb-12 sm:gap-4">
  {homeCategories.map((cat, index) => {
    const categoryPhotos = (photosByCategory[cat.slug] ?? []).slice(0, 2);
    const bandTone = index % 2 === 0
      ? 'bg-linear-to-r from-white/[0.02] via-brand-gold/[0.03] to-white/[0.01]'
      : 'bg-linear-to-r from-white/[0.01] via-brand-gold/[0.03] to-white/[0.02]';

    return (
      <section class={`group relative overflow-hidden rounded-md border border-white/5 p-3 transition-all duration-500 hover:border-brand-gold/40 hover:shadow-[0_0_32px_rgba(212,175,55,0.18)] sm:p-4 lg:p-5 ${bandTone}`}>
        <div class={`mb-2 flex lg:hidden ${index % 2 === 0 ? 'justify-end' : 'justify-start'}`}>
          <div class={`flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.36em] text-brand-gold/80 sm:tracking-[0.45em]`}>
            <span class={`h-0.5 w-10 bg-brand-gold/30 transition-all duration-500 group-hover:w-14 group-hover:bg-brand-gold ${index % 2 === 0 ? 'order-2' : ''}`}></span>
            <span class="font-mono text-[11px] font-semibold tracking-[0.42em] transition-transform duration-500 group-hover:scale-110">{String(index + 1).padStart(2, '0')}</span>
          </div>
        </div>

        <div class="grid items-center gap-4 lg:grid-cols-2 lg:gap-6">
          <div class={`relative z-10 flex flex-col justify-center gap-3 ${index % 2 === 1 ? 'items-end text-right lg:order-2' : 'lg:order-1'}`}>
            <div class={`hidden lg:flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.36em] text-brand-gold/80 sm:tracking-[0.45em] ${index % 2 === 1 ? 'w-full justify-end flex-row-reverse' : ''}`}>
              <span class={`h-0.5 w-10 bg-brand-gold/30 transition-all duration-500 group-hover:w-14 group-hover:bg-brand-gold ${index % 2 === 1 ? 'order-2' : ''}`}></span>
              <span class="font-mono text-[11px] font-semibold tracking-[0.42em] transition-transform duration-500 group-hover:scale-110">{String(index + 1).padStart(2, '0')}</span>
            </div>

            <div class="space-y-2">
              <a href={`/${cat.slug}`} class={`group/link inline-flex items-center gap-3 ${index % 2 === 1 ? 'flex-row-reverse' : ''}`}>
                <h2 class="font-display text-3xl font-black uppercase italic tracking-tight text-white transition-all duration-500 group-hover/link:text-brand-gold sm:text-4xl lg:text-5xl">
                  {cat.name}
                </h2>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`text-brand-gold transition-transform duration-500 group-hover/link:scale-110 ${index % 2 === 1 ? 'group-hover/link:-translate-x-1 mr-6' : 'group-hover/link:translate-x-1 ml-3'}`}>
                  {index % 2 === 1 ? (
                    <>
                      <line x1="19" y1="12" x2="5" y2="12"></line>
                      <polyline points="12 5 5 12 12 19"></polyline>
                    </>
                  ) : (
                    <>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                      <polyline points="12 5 19 12 12 19"></polyline>
                    </>
                  )}
                </svg>
              </a>
              <p class={`text-sm leading-relaxed text-gray-400 max-w-md ${index % 2 === 1 ? 'ml-auto text-right' : ''}`}>
                {cat.copy}
              </p>
            </div>

            <a href={`/${cat.slug}`} class={`group/cta text-[10px] font-bold uppercase tracking-[0.32em] text-gray-500 transition-colors hover:text-brand-gold sm:tracking-[0.4em] ${index % 2 === 1 ? 'self-end' : 'w-fit'}`}>
              <span>View collection</span>
            </a>
          </div>

          <div class={`grid h-52 grid-cols-2 gap-2 sm:h-60 sm:gap-3 lg:h-64 ${index % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}>
            {categoryPhotos.length > 0 ? (
              categoryPhotos.map((photo: GalleryPhoto, photoIndex: number) => {
                const gridImage = getGridImage(photo.image);
                return (
                  <div
                    class="photo-trigger group/photo relative h-full min-h-0 w-full overflow-hidden rounded-sm bg-card-dark shadow-xl"
                    data-photo-card
                    data-full-url={getFullImageUrl(photo.image)}
                    data-title={photo.title}
                  >
                    <picture class="absolute inset-0 block h-full w-full">
                      <source type="image/avif" srcset={gridImage.avifSrcSet} sizes={gridImage.sizes} />
                      <source type="image/webp" srcset={gridImage.webpSrcSet} sizes={gridImage.sizes} />
                      <img
                        src={gridImage.src}
                        alt={photo.alt ?? photo.title}
                        loading={index === 0 && photoIndex === 0 ? 'eager' : 'lazy'}
                        fetchpriority={index === 0 && photoIndex === 0 ? 'high' : 'auto'}
                        sizes={gridImage.sizes}
                        draggable="false"
                        class="h-full w-full object-cover will-change-transform transition-transform duration-1000 ease-out group-hover/photo:scale-102"
                        data-photo-image
                      />
                    </picture>
                    <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/5 to-transparent opacity-90 transition-opacity duration-1000 ease-out group-hover/photo:opacity-75" data-photo-overlay></div>
                    <div class="absolute inset-0 ring-1 ring-white/5 transition-all duration-1000 ease-out group-hover/photo:ring-brand-gold/30" data-photo-accent></div>
                  </div>
                );
              })
            ) : (
              <>
                <div class="flex h-full items-center justify-center rounded-sm border border-white/5 bg-black/25 px-4 text-center text-[10px] font-bold uppercase tracking-[0.35em] text-gray-600">
                  More work coming soon
                </div>
                <div class="flex h-full items-center justify-center rounded-sm border border-white/5 bg-black/20 px-4 text-center text-[10px] font-bold uppercase tracking-[0.35em] text-gray-600">
                  Coming soon
                </div>
              </>
            )}

            {categoryPhotos.length === 1 && (
              <div class="flex h-full items-center justify-center rounded-sm border border-white/5 bg-black/20 px-4 text-center text-[10px] font-bold uppercase tracking-[0.35em] text-gray-600">
                Coming soon
              </div>
            )}
          </div>
        </div>
      </section>
    );
  })}
</div>
