---
// src/components/HomeMatrix.astro
// Editorial grid matrix — 2 per row, full portrait frames

import { homeCategories, type HomeCategory, type HomeCategorySlug } from '../data/homeCategories';
import { getResponsiveImage } from '../utils/imageUrl';
import type { SanityImageSource } from '../utils/imageUrl';

type GalleryPhoto = {
  image: SanityImageSource;
  title: string;
  alt?: string;
  category?: string;
};

interface Props {
  photosByCategory: Record<HomeCategorySlug, GalleryPhoto[]>;
}

const { photosByCategory } = Astro.props;

const bySlug = Object.fromEntries(homeCategories.map((cat) => [cat.slug, cat])) as Record<HomeCategorySlug, HomeCategory>;

const rows: [HomeCategorySlug, HomeCategorySlug][] = [
  ['automotive', 'sports'],
  ['portraits', 'nature'],
  ['graduation', 'cityscape'],
];

const getCellImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [480, 720, 960, 1200, 1600, 2000],
  sizes: '(max-width: 768px) 100vw, 50vw',
  fit: 'max',
});
---

<section class="w-full pb-12 lg:pb-14">
  <div class="flex flex-col gap-2 sm:gap-3">
    {rows.map((row, rowIndex) => (
      <div class="grid grid-cols-1 gap-2 sm:gap-3 md:grid-cols-2 md:items-stretch">
        {row.map((slug, cellIndex) => {
          const cat = bySlug[slug];
          const isPortrait = cat.orientation === 'portrait';
          const leadPhoto = (photosByCategory[slug] ?? [])[0];
          const cellImage = leadPhoto ? getCellImage(leadPhoto.image) : null;
          const displayIndex = homeCategories.findIndex((item) => item.slug === slug);

          return (
            <a
              href={`/${slug}`}
              class={`group relative flex overflow-hidden bg-card-dark ${isPortrait ? 'aspect-[2/3]' : 'aspect-[3/2] md:aspect-auto md:min-h-full'}`}
              style={`animation: home-matrix-in 750ms cubic-bezier(0.22, 1, 0.36, 1) ${(rowIndex * 2 + cellIndex) * 80}ms both;`}
            >
              {!isPortrait && <div class="pointer-events-none invisible hidden aspect-[2/3] md:block" aria-hidden="true"></div>}

              <div class="absolute inset-0">
                {cellImage && leadPhoto ? (
                  <picture class="absolute inset-0 block h-full w-full">
                    <source type="image/avif" srcset={cellImage.avifSrcSet} sizes={cellImage.sizes} />
                    <source type="image/webp" srcset={cellImage.webpSrcSet} sizes={cellImage.sizes} />
                    <img
                      src={cellImage.src}
                      alt={leadPhoto.alt ?? leadPhoto.title}
                      loading={rowIndex === 0 ? 'eager' : 'lazy'}
                      fetchpriority={rowIndex === 0 && cellIndex === 0 ? 'high' : 'auto'}
                      sizes={cellImage.sizes}
                      draggable="false"
                      class={`h-full w-full object-cover transition-transform duration-[1100ms] ease-out group-hover:scale-105 ${isPortrait ? 'object-[center_18%]' : 'object-center'}`}
                    />
                  </picture>
                ) : (
                  <div class="absolute inset-0 bg-linear-to-br from-white/[0.03] via-brand-gold/[0.05] to-black"></div>
                )}

                <div class={`absolute inset-0 transition-opacity duration-500 ${isPortrait ? 'bg-linear-to-t from-black/80 via-transparent to-transparent' : 'bg-linear-to-t from-black/85 via-black/25 to-transparent'} group-hover:opacity-90`}></div>
                <div class="absolute inset-0 ring-1 ring-inset ring-white/5 transition-all duration-500 group-hover:ring-brand-gold/35"></div>
              </div>

              <div class="absolute inset-x-0 bottom-0 z-10 p-3 sm:p-5">
                <div class="mb-1.5 flex items-center gap-2">
                  <span class="h-px w-5 bg-brand-gold/40 transition-all duration-500 group-hover:w-8 group-hover:bg-brand-gold"></span>
                  <span class="font-mono text-[9px] font-semibold tracking-[0.38em] text-brand-gold/75 sm:text-[10px]">
                    {String(displayIndex + 1).padStart(2, '0')}
                  </span>
                </div>
                <h3 class={`font-display font-black uppercase italic tracking-tight text-white transition-colors duration-500 group-hover:text-brand-gold ${isPortrait ? 'text-2xl sm:text-3xl lg:text-4xl' : 'text-xl sm:text-2xl lg:text-3xl'}`}>
                  {cat.name}
                </h3>
                <p class="mt-2 max-w-sm text-xs leading-relaxed text-gray-400 opacity-90 transition-all duration-500 sm:text-sm">
                  {cat.copy}
                </p>
              </div>
            </a>
          );
        })}
      </div>
    ))}
  </div>
</section>

<style>
  @keyframes home-matrix-in {
    from {
      opacity: 0;
      transform: translateY(14px);
      filter: saturate(0.7);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: saturate(1);
    }
  }
</style>
