---
// src/components/Hero.astro
---
<section class="relative flex h-[80vh] items-center justify-center overflow-hidden bg-obsidian">
  <div class="absolute inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-b from-obsidian/20 via-obsidian/60 to-obsidian z-10"></div>
    <img 
      src="https://res.cloudinary.com/decb5tycx/image/upload/v1774320592/samples/ecommerce/car-interior-design.jpg" 
      class="h-full w-full object-cover grayscale-[20%]" 
      alt="Cinematic Automotive Photography"
    />
  </div>

  <div class="relative z-20 text-center px-4">
    <h2 class="font-display text-xs font-bold tracking-[0.3em] text-brand-gold uppercase mb-4">
      Not Just Photos — Visual Impact
    </h2>
    <h1 class="max-w-4xl font-display text-5xl md:text-7xl font-black text-white leading-tight uppercase">
      Capturing the <span class="text-transparent bg-clip-text bg-gradient-to-r from-white via-brand-gold to-white">Rhythm of Motion</span>
    </h1>
  </div>
</section>