---
// src/components/Header.astro

import siteData from '../data/site.json';
---
<nav class="fixed top-0 z-50 w-full border-b border-white/5 bg-obsidian/80 backdrop-blur-md">
  <div class="mx-auto flex max-w-7xl items-center justify-between p-4 md:px-8">
    <div class="flex items-center gap-3">
      <img 
        src={siteData.logo} 
        alt="Ali1_Visuals Logo" 
        class="h-10 w-10 shrink-0" />
      <span class="font-display text-lg font-bold tracking-widest text-white uppercase">
        Ali1<span class="text-brand-gold"></span>Visuals
      </span>
    </div>
    
    <div class="hidden space-x-8 md:flex">
      {['Sports', 'Auto', 'Portraits', 'Nature'].map((item) => (
        <a href={`#${item.toLowerCase()}`} class="text-xs font-medium tracking-tighter text-gray-400 transition-colors hover:text-brand-gold uppercase">
          {item}
        </a>
      ))}
    </div>
  </div>
</nav>