---
// src/pages/faq.astro

import Layout from '../layouts/Layout.astro';
import faqData from '../data/faq.json';

// Transform the JSON object into a simpler array to loop through easily
const faqs = [
  { q: faqData.faq_1, a: faqData.faq_1_ans },
  { q: faqData.faq_2, a: faqData.faq_2_ans },
  { q: faqData.faq_3, a: faqData.faq_3_ans },
  { q: faqData.faq_4, a: faqData.faq_4_ans },
  { q: faqData.faq_5, a: faqData.faq_5_ans },
];
---

<Layout title="FAQ | Ali1_Visuals">
  <main class="bg-obsidian">
    <div class="h-20 sm:h-24 md:h-28"></div>

    <section class="mx-auto max-w-4xl px-4 pt-2 pb-0 sm:px-6 sm:pb-2">
      <header class="mb-10 text-center sm:mb-12 md:mb-15">
        <h1 class="mb-3 font-display text-[10px] font-bold uppercase tracking-[0.28em] text-brand-gold sm:mb-4 sm:tracking-[0.5em]">
          Common Inquiries
        </h1>
        <h2 class="font-display text-3xl font-black uppercase tracking-tight text-white sm:text-4xl md:text-5xl">
          Frequently Asked <span class="text-transparent bg-clip-text bg-linear-to-r from-white to-gray-500">Questions</span>
        </h2>
      </header>

      <div class="space-y-3 sm:space-y-4">
        {faqs.map((faq, index) => (
          <div class="border border-white/4 bg-card-dark transition-all duration-500 has-checked:border-brand-gold/40 has-checked:shadow-[0_0_30px_rgba(197,160,89,0.15)] has-checked:border-2">
            {/* 1. The Hidden Checkbox */}
            <input type="checkbox" id={`faq-${index}`} class="peer hidden" />
            
            {/* 2. The Label (Acts as the Summary) */}
            <label for={`faq-${index}`} class="flex cursor-pointer items-start justify-between gap-3 p-4 outline-none sm:items-center sm:p-6">
              <span class="pr-2 font-display text-xs font-bold uppercase tracking-[0.16em] text-white transition-colors peer-checked:text-brand-gold sm:text-sm sm:tracking-widest">
                {faq.q}
              </span>
              
              {/* The Icon */}
              <span class="faq-icon shrink-0 text-brand-gold transition-all duration-700">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="drop-shadow-[0_0_5px_rgba(197,160,89,0.3)]">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="14.31" y1="8" x2="20.05" y2="17.94"></line>
                  <line x1="9.69" y1="8" x2="21.17" y2="8"></line>
                  <line x1="7.38" y1="12" x2="13.12" y2="2.06"></line>
                  <line x1="9.69" y1="16" x2="3.95" y2="6.06"></line>
                  <line x1="14.31" y1="16" x2="2.83" y2="16"></line>
                  <line x1="16.62" y1="12" x2="10.88" y2="21.94"></line>
                </svg>
              </span>
            </label>

            {/* 3. The Content */}
            <div class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 peer-checked:grid-rows-[1fr]">
              <div class="overflow-hidden">
                <div class="border-t border-white/7 px-4 pb-4 pt-3 text-xs leading-relaxed text-gray-400 opacity-0 transition-opacity duration-500 peer-checked:opacity-100 sm:px-6 sm:pb-6 sm:pt-4 sm:text-sm">
                  <p set:html={faq.a} />
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 border-t border-white/10 pt-6 text-center sm:mt-12 md:mt-15">
        <p class="mb-5 text-[10px] uppercase tracking-[0.2em] text-gray-500 sm:mb-6 sm:text-xs sm:tracking-widest">Still have questions?</p>
        <a href="/contact" class="inline-block bg-brand-gold px-7 py-3 text-[9px] font-black uppercase tracking-[0.2em] text-black transition-all hover:bg-brand-light-gold sm:px-10 sm:py-4 sm:text-[10px] sm:tracking-[0.3em]">
          Contact Asad Directly
        </a>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* 1. Target the text container inside the grid when the checkbox is checked */
  input:checked ~ div > div > div {
    opacity: 1 !important;
    transform: translateY(0) !important;
    transition: opacity 0.5s ease, transform 0.5s ease;
    transition-delay: 0.1s;
  }

  /* 2. Initial state for the text (hidden) */
  .grid > div > div {
    opacity: 0;
    transform: translateY(-10px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  /* 3. Icon glow when checked */
  input:checked ~ label .faq-icon {
    filter: drop-shadow(0 0 10px rgba(197, 160, 89, 0.5));
    transform: rotate(180deg) scale(1.35);
  }

  .faq-icon {
    transform: rotate(0deg) scale(1);
  }

  /* 4. Prevent blue highlight on mobile tap for the label */
  label {
    -webkit-tap-highlight-color: transparent;
  }
</style>