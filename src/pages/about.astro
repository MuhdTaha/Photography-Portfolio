---
import Layout from '../layouts/Layout.astro';
import siteData from '../data/site.json';
---

<Layout title="About | Ali1_Visuals">
  <main class="min-h-screen bg-obsidian">
    <div class="h-10 md:h-10"></div>

    <section class="mx-auto max-w-7xl px-6 py-12 md:py-24">
      <div class="grid items-center gap-12 md:grid-cols-2 lg:gap-24">
        
        <div class="relative order-2 md:order-1">
          <div class="absolute -bottom-4 -left-4 h-full w-full border border-brand-gold/30"></div>
          <div class="relative overflow-hidden bg-card-dark shadow-2xl">
            <img 
              src={siteData.logo} 
              alt="Asad Alibhai - Photographer" 
              class="aspect-4/5 w-full object-cover transition-all duration-700 hover:scale-110"
            />
          </div>
          <div class="absolute -top-2 -right-2 h-8 w-8 border-t-2 border-r-2 border-brand-gold"></div>
        </div>

        <div class="order-1 md:order-2">
          <h1 class="font-display text-xs font-bold uppercase tracking-[0.5em] text-brand-gold">
            The Visionary
          </h1>
          <h2 class="mt-4 font-display text-5xl font-black uppercase tracking-tighter text-white md:text-7xl">
            Asad <br /> <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-500">Alibhai</span>
          </h2>
          
          <div class="mt-8 space-y-6">
            <p class="text-lg leading-relaxed text-gray-300 font-light">
              {siteData.about_text}
            </p>
            
            <div class="h-px w-20 bg-brand-gold/50"></div>
            
            <div class="flex items-center gap-8">
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-500">Specialties</p>
                <p class="mt-1 text-sm font-medium text-white">Auto • Sports • Portraits</p>
              </div>
              <div>
                <p class="text-[10px] font-bold uppercase tracking-widest text-gray-500">Based In</p>
                <p class="mt-1 text-sm font-medium text-white">IL & IN, USA</p>
              </div>
            </div>

            <div class="pt-8">
              <a href="/contact" class="inline-block border border-brand-gold px-8 py-4 text-[10px] font-black uppercase tracking-[0.3em] text-brand-gold transition-all duration-700 hover:bg-brand-gold hover:text-black">
                Work With Me
              </a>
            </div>
          </div>
        </div>

      </div>
    </section>
  </main>
</Layout>