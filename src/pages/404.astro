---
// src/pages/404.astro

import Layout from '../layouts/Layout.astro';
---

<Layout
  title="404 | Ali1_Visuals"
  description="The page you are looking for could not be found."
  noindex={true}
>
  <main class="relative min-h-screen overflow-hidden bg-obsidian">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_22%_18%,rgba(197,160,89,0.14),transparent_42%),radial-gradient(circle_at_78%_80%,rgba(197,160,89,0.12),transparent_40%)]"></div>

    <section class="relative mx-auto flex min-h-screen max-w-7xl items-center px-6 py-24">
      <div class="w-full text-center">
        <p class="mb-5 font-display text-[10px] font-black uppercase tracking-[0.42em] text-brand-gold sm:text-xs">
          Lost In The Frame
        </p>

        <h1 class="font-display text-[5.2rem] font-black uppercase leading-[0.82] tracking-tight text-white sm:text-[8.5rem] md:text-[11rem]">
          404
        </h1>

        <div class="mx-auto mt-6 h-px w-40 bg-linear-to-r from-transparent via-brand-gold/70 to-transparent"></div>

        <p class="mx-auto mt-8 max-w-2xl text-sm italic leading-relaxed text-gray-400 sm:text-base md:text-lg">
          This page does not exist, but the story is still being written. Return to the gallery and explore the latest work.
        </p>

        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/"
            class="inline-flex items-center justify-center border border-brand-gold/60 px-8 py-3 text-[10px] font-black uppercase tracking-[0.28em] text-white transition-all hover:bg-brand-gold hover:text-black"
          >
            Back To Home
          </a>

          <a
            href="/contact"
            class="inline-flex items-center justify-center border border-white/15 px-8 py-3 text-[10px] font-black uppercase tracking-[0.28em] text-gray-300 transition-all hover:border-brand-gold/40 hover:text-brand-gold"
          >
            Contact
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
