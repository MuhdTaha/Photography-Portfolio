---
// src/pages/index.astro

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { client } from '../lib/sanity';
import { HOMEPAGE_PHOTOS_QUERY } from '../utils/queries';
import siteData from '../data/site.json';
import { getImageUrl, getResponsiveImage } from '../utils/imageUrl';
import type { SanityImageSource } from '../utils/imageUrl';

type GalleryPhoto = {
  image: SanityImageSource;
  title: string;
  alt?: string;
  category?: string;
};

type HomepagePhotos = Record<CategorySlug, GalleryPhoto[]>;

const categories = ['Automotive', 'Sports', 'Portraits', 'Nature'];
const categoryCopy = {
  automotive: 'Clean lines, motion, and the kind of frame that makes horsepower feel sculpted.',
  sports: 'Fast hands, sharp timing, and the split-second energy that turns a play into a story.',
  portraits: 'Confident, honest, and shaped around the personality that lives just under the surface.',
  nature: 'Quiet light, wide air, and the details that make the outdoors feel cinematic.',
} satisfies Record<string, string>;
type CategorySlug = keyof typeof categoryCopy;

const photosByCategory = await client.fetch<HomepagePhotos>(HOMEPAGE_PHOTOS_QUERY);

const getGridImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [640, 960, 1100, 1400, 1800],
  sizes: '(max-width: 1024px) 100vw, 50vw',
  fit: 'max',
});

const getSupportingImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [480, 720, 960, 1200],
  sizes: '(max-width: 1024px) 50vw, 25vw',
  fit: 'max',
});

const getFullImageUrl = (image: SanityImageSource) => getImageUrl(image, { width: 2000, fit: 'max', quality: 85, format: 'auto' });
---

<Layout
  title="Ali1_Visuals | Discover Stunning Visuals"
  description="Explore Ali1_Visuals photography portfolio featuring cinematic automotive, sports, portraits, and nature work."
>
  <main class="bg-obsidian">
    <Hero />

    <section class="mx-auto w-full max-w-2xl px-5 py-10 text-center sm:px-6 sm:py-12 md:py-14">
      <h1 class="mb-3 font-display text-[9px] font-bold uppercase tracking-[0.3em] text-brand-gold sm:text-[10px] sm:tracking-[0.5em]">The Vision</h1>
      <p class="text-sm font-light leading-relaxed text-gray-300 italic sm:text-lg md:text-xl">
        "{siteData.home_text}"
      </p>
    </section>

    <div class="mx-auto flex w-full max-w-7xl flex-col gap-6 px-4 pb-12 sm:px-6 lg:px-8">
      {categories.map((cat, index) => {
        const categorySlug = cat.toLowerCase() as CategorySlug;
        const categoryPhotos = photosByCategory[categorySlug] ?? [];
        const leadPhoto = categoryPhotos[0];
        const supportingPhotos = categoryPhotos.slice(1, 3);
        const categoryText = categoryCopy[categorySlug];
        const bandTone = index % 2 === 0
          ? 'bg-linear-to-r from-white/[0.02] via-brand-gold/[0.03] to-white/[0.01]'
          : 'bg-linear-to-r from-white/[0.01] via-brand-gold/[0.03] to-white/[0.02]';

        return (
          <section class={`group relative overflow-hidden rounded-md border border-white/5 p-4 transition-all duration-500 hover:border-brand-gold/40 hover:shadow-[0_0_32px_rgba(212,175,55,0.18)] sm:p-6 lg:p-8 ${bandTone}`}>
            <div class={`mb-4 flex lg:hidden ${index % 2 === 0 ? 'justify-end' : 'justify-start'}`}>
              <div class={`flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.36em] text-brand-gold/80 sm:tracking-[0.45em]`}>
                <span class={`h-0.5 w-12 bg-brand-gold/30 transition-all duration-500 group-hover:w-16 group-hover:bg-brand-gold ${index % 2 === 0 ? 'order-2' : ''}`}></span>
                <span class="font-mono text-[11px] font-semibold tracking-[0.42em] transition-transform duration-500 group-hover:scale-110 sm:text-[12px]">{String(index + 1).padStart(2, '0')}</span>
              </div>
            </div>

            <div class="grid items-center gap-8 lg:grid-cols-2">
              
              {/* Text Information Column */}
              <div class={`relative z-10 flex flex-col justify-center gap-6 ${index % 2 === 1 ? 'items-end text-right lg:order-2' : 'lg:order-1'}`}>
                <div class={`hidden lg:flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.36em] text-brand-gold/80 sm:tracking-[0.45em] ${index % 2 === 1 ? 'w-full justify-end flex-row-reverse' : ''}`}>
                  <span class={`h-0.5 w-12 bg-brand-gold/30 transition-all duration-500 group-hover:w-16 group-hover:bg-brand-gold ${index % 2 === 1 ? 'order-2' : ''}`}></span>
                  <span class="font-mono text-[11px] font-semibold tracking-[0.42em] transition-transform duration-500 group-hover:scale-110 sm:text-[12px]">{String(index + 1).padStart(2, '0')}</span>
                </div>

                <div class="space-y-3">
                  <a href={`/${categorySlug}`} class={`group/link inline-flex items-center gap-3 ${index % 2 === 1 ? 'flex-row-reverse' : ''}`}>
                    <h2 class="font-display text-4xl font-black uppercase italic tracking-tight text-white transition-all duration-500 group-hover/link:text-brand-gold sm:text-5xl lg:text-6xl">
                      {cat}
                    </h2>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class={`text-brand-gold transition-transform duration-500 group-hover/link:scale-110 ${index % 2 === 1 ? 'group-hover/link:-translate-x-1 mr-8' : 'group-hover/link:translate-x-1 ml-4'}`}>
                      {index % 2 === 1 ? (
                        <>
                          <line x1="19" y1="12" x2="5" y2="12"></line>
                          <polyline points="12 5 5 12 12 19"></polyline>
                        </>
                      ) : (
                        <>
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </>
                      )}
                    </svg>
                  </a>
                  <p class={`text-sm leading-relaxed text-gray-400 sm:text-base max-w-md ${index % 2 === 1 ? 'ml-auto text-right' : ''}`}>
                    {categoryText}
                  </p>
                </div>

                <a href={`/${categorySlug}`} class={`group/cta text-[10px] font-bold uppercase tracking-[0.32em] text-gray-500 transition-colors hover:text-brand-gold sm:tracking-[0.4em] ${index % 2 === 1 ? 'self-end' : 'w-fit'}`}>
                  <span>View collection</span>
                </a>
              </div>

              {/* Visual Images Display Column */}
              <div class={`grid grid-cols-2 gap-3 sm:gap-4 ${index % 2 === 1 ? 'lg:order-1' : 'lg:order-2'}`}>
                {leadPhoto ? (
                  (() => {
                    const leadImage = getGridImage(leadPhoto.image);
                    return (
                      <div
                        class="photo-trigger group/photo relative aspect-2/3 w-full overflow-hidden rounded-sm bg-card-dark shadow-xl"
                        data-photo-card
                        data-full-url={getFullImageUrl(leadPhoto.image)}
                        data-title={leadPhoto.title}
                      >
                        <picture class="absolute inset-0 block h-full w-full">
                          <source type="image/avif" srcset={leadImage.avifSrcSet} sizes={leadImage.sizes} />
                          <source type="image/webp" srcset={leadImage.webpSrcSet} sizes={leadImage.sizes} />
                          <img
                            src={leadImage.src}
                            alt={leadPhoto.alt ?? leadPhoto.title}
                            loading={index === 0 ? 'eager' : 'lazy'}
                            fetchpriority={index === 0 ? 'high' : 'auto'}
                            sizes={leadImage.sizes}
                            draggable="false"
                            class="h-full w-full object-cover will-change-transform transition-transform duration-1000 ease-out group-hover/photo:scale-102"
                            data-photo-image
                          />
                        </picture>
                        <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/5 to-transparent opacity-90 transition-opacity duration-1000 ease-out group-hover/photo:opacity-75" data-photo-overlay></div>
                        <div class="absolute inset-0 ring-1 ring-white/5 transition-all duration-1000 ease-out group-hover/photo:ring-brand-gold/30" data-photo-accent></div>
                      </div>
                    );
                  })()
                ) : (
                  <div class="flex aspect-2/3 items-center justify-center rounded-sm border border-white/5 bg-black/25 px-6 text-center text-[10px] font-bold uppercase tracking-[0.35em] text-gray-600">
                    More work coming soon
                  </div>
                )}

                {/* Supporting Images Column Stack */}
                <div class="grid grid-rows-2 gap-3 sm:gap-4">
                  {supportingPhotos.map((photo: GalleryPhoto) => (
                    (() => {
                      const supportingImage = getSupportingImage(photo.image);
                      return (
                        <div
                          class="photo-trigger group/photo relative h-full w-full overflow-hidden rounded-sm bg-card-dark shadow-md"
                          data-photo-card
                          data-full-url={getFullImageUrl(photo.image)}
                          data-title={photo.title}
                        >
                          <picture class="absolute inset-0 block h-full w-full">
                            <source type="image/avif" srcset={supportingImage.avifSrcSet} sizes={supportingImage.sizes} />
                            <source type="image/webp" srcset={supportingImage.webpSrcSet} sizes={supportingImage.sizes} />
                            <img
                              src={supportingImage.src}
                              alt={photo.alt ?? photo.title}
                              loading="lazy"
                              fetchpriority="auto"
                              sizes={supportingImage.sizes}
                              draggable="false"
                              class="h-full w-full object-cover will-change-transform transition-transform duration-1000 ease-out group-hover/photo:scale-102"
                              data-photo-image
                            />
                          </picture>
                          <div class="absolute inset-0 bg-linear-to-t from-black/60 via-black/5 to-transparent opacity-90 transition-opacity duration-1000 ease-out group-hover/photo:opacity-75" data-photo-overlay></div>
                          <div class="absolute inset-0 ring-1 ring-white/5 transition-all duration-1000 ease-out group-hover/photo:ring-brand-gold/30" data-photo-accent></div>
                        </div>
                      );
                    })()
                  ))}

                  {supportingPhotos.length === 0 && (
                    <div class="row-span-2 flex items-center justify-center rounded-sm border border-white/5 bg-black/20 text-center text-[9px] font-bold uppercase tracking-[0.35em] text-gray-600">
                      Select works collection
                    </div>
                  )}
                  {supportingPhotos.length === 1 && (
                    <div class="flex items-center justify-center rounded-sm border border-white/5 bg-black/20 text-center text-[9px] font-bold uppercase tracking-[0.35em] text-gray-600">
                      Coming soon
                    </div>
                  )}
                </div>

              </div>
            </div>

            

          </section>
        );
      })}
    </div>
  </main>
</Layout>