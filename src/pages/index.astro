---
// src/pages/index.astro

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import HomeBands from '../components/HomeBands.astro';
import HomeSplit from '../components/HomeSplit.astro';
import HomeMatrix from '../components/HomeMatrix.astro';
import { client } from '../lib/sanity';
import { HOMEPAGE_PHOTOS_QUERY } from '../utils/queries';
import siteData from '../data/site.json';
import type { HomeCategorySlug } from '../data/homeCategories';
import type { SanityImageSource } from '../utils/imageUrl';

type GalleryPhoto = {
  image: SanityImageSource;
  title: string;
  alt?: string;
  category?: string;
};

type HomepagePhotos = Record<HomeCategorySlug, GalleryPhoto[]>;

/** Switch homepage layout while experimenting: 'bands' | 'split' | 'matrix' */
const homeLayout = 'split' as 'bands' | 'split' | 'matrix';

const photosByCategory = await client.fetch<HomepagePhotos>(HOMEPAGE_PHOTOS_QUERY);
---

<Layout
  title="Ali1_Visuals | Discover Stunning Visuals"
  description="Explore Ali1_Visuals photography portfolio featuring cinematic automotive, sports, portraits, nature, graduation, and cityscape work."
>
  <main class="bg-obsidian">
    <Hero />

    <section class="mx-auto w-full max-w-2xl px-5 py-10 text-center sm:px-6 sm:py-12 md:py-14">
      <h1 class="mb-3 font-display text-[9px] font-bold uppercase tracking-[0.3em] text-brand-gold sm:text-[10px] sm:tracking-[0.5em]">The Vision</h1>
      <p class="text-sm font-light leading-relaxed text-gray-300 italic sm:text-lg md:text-xl">
        "{siteData.home_text}"
      </p>
    </section>

    <div class="mx-auto w-full max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="border-t border-white/10 pt-12 sm:pt-14 md:pt-16">
        <header class="mb-10 text-center sm:mb-12 md:mb-14">
          <p class="mb-3 font-display text-[9px] font-bold uppercase tracking-[0.3em] text-brand-gold sm:text-[10px] sm:tracking-[0.5em]">Explore the work</p>
          <h2 class="font-display text-3xl font-black uppercase italic tracking-tight text-white sm:text-4xl md:text-5xl">
            Collections
          </h2>
        </header>

        {homeLayout === 'bands' && <HomeBands photosByCategory={photosByCategory} />}
        {homeLayout === 'split' && <HomeSplit photosByCategory={photosByCategory} />}
        {homeLayout === 'matrix' && <HomeMatrix photosByCategory={photosByCategory} />}
      </div>
    </div>
  </main>
</Layout>
