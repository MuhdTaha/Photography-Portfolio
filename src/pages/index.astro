---
// src/pages/index.astro

import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import { client } from '../lib/sanity';
import { ALL_PHOTOS_QUERY } from '../utils/queries';
import siteData from '../data/site.json';
import { getImageUrl, getResponsiveImage } from '../utils/imageUrl';
import type { SanityImageSource } from '../utils/imageUrl';

type GalleryPhoto = {
  image: SanityImageSource;
  title: string;
  alt?: string;
  category?: string;
};

const photos = await client.fetch(ALL_PHOTOS_QUERY) as GalleryPhoto[];
const categories = ['Automotive', 'Sports', 'Portraits', 'Nature'];
const categoryCopy = {
  automotive: 'Clean lines, motion, and the kind of frame that makes horsepower feel sculpted.',
  sports: 'Fast hands, sharp timing, and the split-second energy that turns a play into a story.',
  portraits: 'Confident, honest, and shaped around the personality that lives just under the surface.',
  nature: 'Quiet light, wide air, and the details that make the outdoors feel cinematic.',
} satisfies Record<string, string>;
type CategorySlug = keyof typeof categoryCopy;

const getGridImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [640, 960, 1100, 1400, 1800],
  sizes: '(max-width: 1024px) 100vw, 60vw',
  fit: 'max',
});

const getSupportingImage = (image: SanityImageSource) => getResponsiveImage(image, {
  widths: [480, 720, 960, 1200],
  sizes: '(max-width: 1024px) 50vw, 25vw',
  fit: 'max',
});

const getFullImageUrl = (image: SanityImageSource) => getImageUrl(image, { width: 2000, fit: 'max', quality: 85, format: 'auto' });
---

<Layout
  title="Ali1_Visuals | Discover Stunning Visuals"
  description="Explore Ali1_Visuals photography portfolio featuring cinematic automotive, sports, portraits, and nature work."
>
  <main class="bg-obsidian">
    <Hero />

    <section class="mx-auto w-full max-w-2xl px-5 py-10 text-center sm:px-6 sm:py-12 md:py-14">
      <h1 class="mb-3 font-display text-[9px] font-bold uppercase tracking-[0.3em] text-brand-gold sm:text-[10px] sm:tracking-[0.5em]">The Vision</h1>
      <p class="text-sm font-light leading-relaxed text-gray-300 italic sm:text-lg md:text-xl">
        "{siteData.home_text}"
      </p>
    </section>

    <div class="mx-auto flex w-full max-w-7xl flex-col gap-3 px-3 pb-4 sm:px-4 sm:pb-6 lg:px-6">
      {categories.map((cat, index) => {
        const categorySlug = cat.toLowerCase() as CategorySlug;
        const categoryPhotos = photos.filter((photo: GalleryPhoto) => photo.category?.toLowerCase() === categorySlug).slice(0, 3);
        const leadPhoto = categoryPhotos[0];
        const supportingPhotos = categoryPhotos.slice(1, 3);
        const categoryText = categoryCopy[categorySlug];
        const bandTone = index % 2 === 0
          ? 'bg-linear-to-r from-white/[0.03] via-brand-gold/8 to-white/[0.01]'
          : 'bg-linear-to-r from-white/[0.01] via-brand-gold/8 to-white/[0.03]';

        return (
          <section class={`group relative overflow-hidden border-y border-white/5 ${bandTone}`}>
            <div class={`grid min-h-65 items-stretch transition-transform duration-500 group-hover:scale-[1.01] lg:min-h-80 ${index % 2 === 1 ? 'lg:grid-cols-[1.25fr_0.95fr]' : 'lg:grid-cols-[0.95fr_1.25fr]'}`}>
              <div class={`relative z-10 flex flex-col justify-between gap-5 p-5 sm:p-6 lg:p-8 ${index % 2 === 1 ? 'lg:order-2' : 'lg:order-1'}`}>
                <div class={`flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.36em] text-brand-gold/80 sm:tracking-[0.45em] ${index % 2 === 1 ? 'justify-end flex-row-reverse self-end' : ''}`}>
                  <span class={`h-px w-10 bg-brand-gold/50 transition-all duration-500 group-hover:w-14 group-hover:bg-brand-gold ${index % 2 === 1 ? 'order-2' : ''}`}></span>
                  <span class="transition-transform duration-500 group-hover:scale-110">{String(index + 1).padStart(2, '0')}</span>
                </div>

                <div class={`max-w-xl ${index % 2 === 1 ? 'ml-auto text-right' : ''}`}>
                  <a href={`/${categorySlug}`} class={`group/link inline-flex items-center gap-3 ${index % 2 === 1 ? 'flex-row-reverse justify-end' : ''}`}>
                    <h2 class={`relative inline-block pb-1 font-display text-4xl font-black uppercase italic leading-[0.85] tracking-tight text-white transition-all duration-500 after:absolute after:-bottom-0.5 after:h-px after:w-full after:bg-brand-light-gold after:transition-transform after:duration-700 after:ease-out group-hover/link:scale-[1.03] group-hover/link:text-brand-gold group-hover/link:after:scale-x-100 sm:text-5xl lg:text-6xl ${index % 2 === 1 ? 'text-right after:right-0 after:origin-right after:left-auto' : 'after:left-0 after:origin-left'} after:scale-x-0`}>
                      {cat}
                    </h2>
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`translate-y-1 text-brand-gold transition-transform duration-500 group-hover/link:scale-125 ${index % 2 === 1 ? 'group-hover/link:-translate-x-2' : 'group-hover/link:translate-x-2'}`}>
                      {index % 2 === 1 ? (
                        <>
                          <line x1="19" y1="12" x2="5" y2="12"></line>
                          <polyline points="12 5 5 12 12 19"></polyline>
                        </>
                      ) : (
                        <>
                          <line x1="5" y1="12" x2="19" y2="12"></line>
                          <polyline points="12 5 19 12 12 19"></polyline>
                        </>
                      )}
                    </svg>
                  </a>
                  <p class="mt-3 max-w-md text-sm leading-relaxed text-gray-300 sm:text-base">
                    {categoryText}
                  </p>
                </div>

                <a href={`/${categorySlug}`} class={`group/cta inline-flex items-center gap-3 text-[10px] font-bold uppercase tracking-[0.32em] text-gray-500 transition-colors hover:text-brand-gold sm:tracking-[0.4em] ${index % 2 === 1 ? 'justify-end self-end text-right' : 'w-fit'}`}>
                  <span>View collection</span>
                </a>
              </div>

              <div class={`grid gap-2 p-2 sm:gap-3 sm:p-3 ${index % 2 === 1 ? 'lg:order-1 lg:grid-cols-[1.15fr_0.85fr]' : 'lg:order-2 lg:grid-cols-[0.85fr_1.15fr]'}`}>
                {leadPhoto ? (
                  (() => {
                    const leadImage = getGridImage(leadPhoto.image);

                    return (
                  <div
                    class="photo-trigger group/photo relative min-h-55 overflow-hidden rounded-sm bg-card-dark lg:min-h-full"
                    data-photo-card
                    data-full-url={getFullImageUrl(leadPhoto.image)}
                    data-title={leadPhoto.title}
                  >
                    <picture class="block h-full w-full">
                      <source type="image/avif" srcset={leadImage.avifSrcSet} sizes={leadImage.sizes} />
                      <source type="image/webp" srcset={leadImage.webpSrcSet} sizes={leadImage.sizes} />
                      <img
                        src={leadImage.src}
                        alt={leadPhoto.alt ?? leadPhoto.title}
                        loading={index === 0 ? 'eager' : 'lazy'}
                        fetchpriority={index === 0 ? 'high' : 'auto'}
                        sizes={leadImage.sizes}
                        draggable="false"
                        class="h-full w-full object-cover"
                        data-photo-image
                      />
                    </picture>

                    <div class="absolute inset-0 bg-linear-to-t from-black/75 via-black/12 to-transparent opacity-90 transition-opacity duration-500 group-hover/photo:from-black/65" data-photo-overlay></div>
                    <div class="absolute inset-0 ring-0 ring-brand-gold/0 transition-all duration-500 group-hover/photo:ring-1 group-hover/photo:ring-brand-gold/25" data-photo-accent></div>
                  </div>
                    );
                  })()
                ) : (
                  <div class="flex min-h-55 items-center justify-center rounded-sm border border-white/5 bg-black/25 px-6 text-center text-[10px] font-bold uppercase tracking-[0.35em] text-gray-600 lg:min-h-full">
                    More work coming soon
                  </div>
                )}

                <div class="grid grid-cols-2 gap-2 lg:grid-cols-1 lg:grid-rows-2 lg:gap-3">
                  {supportingPhotos.map((photo) => (
                    (() => {
                      const supportingImage = getSupportingImage(photo.image);

                      return (
                    <div
                      class="photo-trigger group/photo relative min-h-27 overflow-hidden rounded-sm bg-card-dark"
                      data-photo-card
                      data-full-url={getFullImageUrl(photo.image)}
                      data-title={photo.title}
                    >
                      <picture class="block h-full w-full">
                        <source type="image/avif" srcset={supportingImage.avifSrcSet} sizes={supportingImage.sizes} />
                        <source type="image/webp" srcset={supportingImage.webpSrcSet} sizes={supportingImage.sizes} />
                        <img
                          src={supportingImage.src}
                          alt={photo.alt ?? photo.title}
                          loading="lazy"
                          fetchpriority="auto"
                          sizes={supportingImage.sizes}
                          draggable="false"
                          class="h-full w-full object-cover"
                          data-photo-image
                        />
                      </picture>

                      <div class="absolute inset-0 bg-linear-to-t from-black/78 via-black/8 to-transparent opacity-85 transition-opacity duration-500 group-hover/photo:from-black/68" data-photo-overlay></div>
                      <div class="absolute inset-0 ring-0 ring-brand-gold/0 transition-all duration-500 group-hover/photo:ring-1 group-hover/photo:ring-brand-gold/25" data-photo-accent></div>
                    </div>
                      );
                    })()
                  ))}

                  {supportingPhotos.length < 2 && (
                    <div class="flex min-h-27 items-center justify-center rounded-sm border border-white/5 bg-black/20 text-[9px] font-bold uppercase tracking-[0.35em] text-gray-600 lg:min-h-0">
                      Select works
                    </div>
                  )}
                </div>
              </div>
            </div>
          </section>
        );
      })}
    </div>
  </main>
</Layout>