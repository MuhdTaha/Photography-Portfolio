---
// src/layouts/Layout.astro

import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import siteData from '../data/site.json';
import Lightbox from '../components/Lightbox.astro';

type JsonLd = Record<string, unknown>;

interface LayoutProps {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  structuredData?: JsonLd | JsonLd[];
}

const {
  title,
  description = 'Ali1_Visuals photography portfolio featuring automotive, sports, portraits, and nature photography.',
  ogImage = siteData.hero_image,
  noindex = false,
  structuredData,
} = Astro.props as LayoutProps;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();
const socialImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';

const defaultStructuredData: JsonLd[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Ali1_Visuals',
    url: new URL('/', Astro.site ?? Astro.url).toString(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: 'Asad Alibhai',
    url: new URL('/', Astro.site ?? Astro.url).toString(),
    email: siteData.email,
    sameAs: [siteData.instagram],
    jobTitle: 'Photographer',
  },
];

const structuredDataPayload = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : defaultStructuredData;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Ali1_Visuals" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    {
      structuredDataPayload.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
    <link rel="icon" type="image/png" href="/favicon.png" />
    <ClientRouter />
  </head>
  <body class="bg-obsidian text-white font-body selection:bg-brand-gold selection:text-black">
    <nav class="fixed top-0 z-50 w-full border-b border-white/5 bg-obsidian/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 md:px-8 md:py-4">
        <a href="/" class="flex items-center gap-2 group">
          <img src={siteData.logo} alt="Ali1_Visuals logo" class="h-8 w-8 transition-transform group-hover:rotate-12" />
          <span class="font-display text-sm font-bold tracking-tight uppercase sm:text-base">Ali1_Visuals</span>
        </a>

        <button
          id="mobile-menu-button"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu"
          aria-label="Toggle navigation menu"
          class="inline-flex items-center justify-center rounded-sm border border-white/10 p-2 text-white/80 transition hover:border-brand-gold/60 hover:text-brand-gold md:hidden"
        >
          <svg id="mobile-menu-open-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
          <svg id="mobile-menu-close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
        
        <div class="hidden md:flex space-x-6 text-xs font-bold tracking-widest uppercase">
          <a href="/" class="relative group transition hover:text-brand-gold">
            Home
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/about" class="relative group transition hover:text-brand-gold">
            About
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/faq" class="relative group transition hover:text-brand-gold">
            FAQ
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/contact" class="relative group transition hover:text-brand-gold">
            Contact
            <span class="absolute -bottom-1   left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a 
            href={siteData.instagram} 
            target="_blank" 
            rel="noopener noreferrer"
            class="relative group text-brand-gold transition-opacity hover:opacity-80"
          >
            Instagram
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full shadow-[0_0_8px_rgba(197,160,89,0.6)]"></span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full shadow-[0_0_8px_rgba(197,160,89,0.6)]"></span>
          </a>
        </div>
      </div>

      <div 
        id="mobile-menu" 
        class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-500 ease-in-out md:hidden border-b border-brand-gold/25 bg-[rgba(10,10,10,0.52)] backdrop-blur-2xl backdrop-saturate-150 shadow-[0_14px_40px_rgba(0,0,0,0.45)]"
      >
        <div class="overflow-hidden">
          <div class="flex flex-col gap-3 px-5 py-6 text-sm font-black uppercase tracking-[0.3em]">
            <a href="/" class="mobile-link group flex items-center justify-between rounded-sm border border-white/8 bg-white/2 px-3 py-2.5 hover:border-brand-gold/45 hover:bg-brand-gold/8">
              <span>Home</span>
              <span class="h-px w-0 bg-brand-gold transition-all duration-500 group-hover:w-12"></span>
            </a>
            <a href="/about" class="mobile-link group flex items-center justify-between rounded-sm border border-white/8 bg-white/2 px-3 py-2.5 hover:border-brand-gold/45 hover:bg-brand-gold/8">
              <span>About</span>
              <span class="h-px w-0 bg-brand-gold transition-all duration-500 group-hover:w-12"></span>
            </a>
            <a href="/faq" class="mobile-link group flex items-center justify-between rounded-sm border border-white/8 bg-white/2 px-3 py-2.5 hover:border-brand-gold/45 hover:bg-brand-gold/8">
              <span>FAQ</span>
              <span class="h-px w-0 bg-brand-gold transition-all duration-500 group-hover:w-12"></span>
            </a>
            <a href="/contact" class="mobile-link group flex items-center justify-between rounded-sm border border-white/8 bg-white/2 px-3 py-2.5 hover:border-brand-gold/45 hover:bg-brand-gold/8">
              <span>Contact</span>
              <span class="h-px w-0 bg-brand-gold transition-all duration-500 group-hover:w-12"></span>
            </a>
            <a href={siteData.instagram} target="_blank" rel="noopener noreferrer" class="mobile-link text-brand-gold flex items-center justify-between rounded-sm border border-brand-gold/35 bg-brand-gold/8 px-3 py-2.5 hover:border-brand-gold/60 hover:bg-brand-gold/14">
              <span>Instagram</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37a4 4 0 1 1-1.09-4.31 4 4 0 0 1 1.09 4.31z"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </nav>

    <slot />
    <Lightbox />

    <footer class="mt-10 border-t border-white/5 bg-card-dark py-7 sm:py-6">
      <div class="mx-auto max-w-7xl px-4 text-center sm:px-6">
        <div class="mt-1 flex flex-col items-center justify-center gap-3 text-[11px] font-bold uppercase tracking-[0.22em] sm:text-xs sm:tracking-widest md:flex-row md:gap-8">
          <a href={`mailto:${siteData.email}`} class="text-white hover:text-brand-gold transition-colors">
            {siteData.email}
          </a>
          
          <span class="hidden md:block text-gray-700">|</span>
          
          <a href={siteData.instagram} target="_blank" rel="noopener noreferrer" class="text-brand-gold hover:opacity-80 transition-opacity">
            Instagram
          </a>
          
          <span class="hidden md:block text-gray-700">|</span>
          
          <span class="text-gray-400">Based in IL & IN</span>
        </div>

        <p class="mt-6 font-display text-[10px] tracking-[0.24em] text-gray-600 uppercase sm:text-[11px] sm:tracking-[0.3em]">
          © 2026 Ali1_Visuals — All Rights Reserved
        </p>

        <div class="mt-6 mb-0">
          <a 
            href="https://github.com/MuhdTaha" 
            target="_blank" 
            rel="noopener noreferrer"
            class="group text-[9px] tracking-[0.28em] text-gray-700 uppercase transition-colors hover:text-brand-gold sm:tracking-[0.4em]"
          >
            Designed & Developed by <span class="font-bold text-gray-500 group-hover:text-brand-gold">MTAHA</span>
          </a>
        </div>
      </div>
    </footer>

    <style is:global>
      /* Reveal the internal content when the grid row expands */
      .menu-open {
        grid-template-rows: 1fr !important;
      }

      /* Liquid Link Animation */
      .mobile-link {
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .links-reveal .mobile-link {
        opacity: 1;
        transform: translateY(0);
      }

      /* Delay each link by 50ms for the "Stagger" effect */
      .mobile-link:nth-child(1) { transition-delay: 0.1s; }
      .mobile-link:nth-child(2) { transition-delay: 0.15s; }
      .mobile-link:nth-child(3) { transition-delay: 0.2s; }
      .mobile-link:nth-child(4) { transition-delay: 0.25s; }
      .mobile-link:nth-child(5) { transition-delay: 0.3s; }
    </style>

    <script>
      type CleanupFn = () => void;

      declare global {
        interface Window {
          __layoutNavCleanup?: CleanupFn;
          __layoutNavPageLoadBound?: boolean;
        }
      }

      function initMobileNav() {
        window.__layoutNavCleanup?.();

        const menuButton = document.getElementById('mobile-menu-button') as HTMLButtonElement | null;
        const mobileMenu = document.getElementById('mobile-menu') as HTMLElement | null;
        const openIcon = document.getElementById('mobile-menu-open-icon');
        const closeIcon = document.getElementById('mobile-menu-close-icon');
        const menuLinks = Array.from(document.querySelectorAll<HTMLElement>('.mobile-link'));

        if (!menuButton || !mobileMenu) return;

        let isOpen = false;
        let revealTimeout: ReturnType<typeof setTimeout> | undefined;

        const syncMenuState = () => {
          mobileMenu.classList.toggle('menu-open', isOpen);

          if (revealTimeout) clearTimeout(revealTimeout);
          if (isOpen) {
            revealTimeout = setTimeout(() => {
              mobileMenu.classList.add('links-reveal');
            }, 40);
          } else {
            mobileMenu.classList.remove('links-reveal');
          }

          openIcon?.classList.toggle('hidden', isOpen);
          closeIcon?.classList.toggle('hidden', !isOpen);
          menuButton.setAttribute('aria-expanded', String(isOpen));
        };

        const toggleMenu = () => {
          isOpen = !isOpen;
          syncMenuState();
        };

        const closeMenu = () => {
          if (!isOpen) return;
          isOpen = false;
          syncMenuState();
        };

        const onResize = () => {
          if (window.innerWidth >= 768) closeMenu();
        };

        const onKeydown = (event: KeyboardEvent) => {
          if (event.key === 'Escape') closeMenu();
        };

        const onDocumentClick = (event: MouseEvent) => {
          if (!isOpen) return;
          if (!(event.target instanceof Node)) return;
          if (mobileMenu.contains(event.target) || menuButton.contains(event.target)) return;
          closeMenu();
        };

        const onMenuLinkClick = () => {
          closeMenu();
        };

        menuButton.addEventListener('click', toggleMenu);
        window.addEventListener('resize', onResize);
        document.addEventListener('keydown', onKeydown);
        document.addEventListener('click', onDocumentClick);
        menuLinks.forEach((link) => link.addEventListener('click', onMenuLinkClick));

        syncMenuState();

        window.__layoutNavCleanup = () => {
          if (revealTimeout) clearTimeout(revealTimeout);
          menuButton.removeEventListener('click', toggleMenu);
          window.removeEventListener('resize', onResize);
          document.removeEventListener('keydown', onKeydown);
          document.removeEventListener('click', onDocumentClick);
          menuLinks.forEach((link) => link.removeEventListener('click', onMenuLinkClick));
        };
      }

      if (!window.__layoutNavPageLoadBound) {
        document.addEventListener('astro:page-load', initMobileNav);
        window.__layoutNavPageLoadBound = true;
      }

      initMobileNav();
    </script>
  </body>
</html>