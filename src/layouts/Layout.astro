---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import siteData from '../data/site.json';
import Lightbox from '../components/Lightbox.astro';

const { title } = Astro.props;
---

<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <ClientRouter />
  </head>
  <body class="bg-obsidian text-white font-body selection:bg-brand-gold selection:text-black">
    <nav class="fixed top-0 z-50 w-full border-b border-white/5 bg-obsidian/80 backdrop-blur-md">
      <div class="mx-auto flex max-w-7xl items-center justify-between p-4 md:px-8">
        <a href="/" class="flex items-center gap-2 group">
          <img src={siteData.logo} alt="Logo" class="h-8 w-8 transition-transform group-hover:rotate-12" />
          <span class="font-display font-bold tracking-tighter uppercase">Ali1_Visuals</span>
        </a>
        
        <div class="hidden md:flex space-x-6 text-xs font-bold tracking-widest uppercase">
          <a href="/" class="relative group transition hover:text-brand-gold">
            Home
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/about" class="relative group transition hover:text-brand-gold">
            About
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/faq" class="relative group transition hover:text-brand-gold">
            FAQ
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a href="/contact" class="relative group transition hover:text-brand-gold">
            Contact
            <span class="absolute -bottom-1   left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full"></span>
          </a>

          <a 
            href={siteData.instagram} 
            target="_blank" 
            rel="noopener noreferrer"
            class="relative group text-brand-gold transition-opacity hover:opacity-80"
          >
            Instagram
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full shadow-[0_0_8px_rgba(197,160,89,0.6)]"></span>
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-brand-gold transition-all duration-300 group-hover:w-full shadow-[0_0_8px_rgba(197,160,89,0.6)]"></span>
          </a>
        </div>
      </div>
    </nav>

    <slot />
    <Lightbox />

    <footer class="border-t border-white/5 bg-card-dark py-4 mt-10">
      <div class="max-w-7xl mx-auto px-0 py-0 text-center">
        <div class="flex flex-col md:flex-row justify-center items-center mt-2 gap-4 md:gap-8 text-xs font-bold uppercase tracking-widest">
          <a href={`mailto:${siteData.email}`} class="text-white hover:text-brand-gold transition-colors">
            {siteData.email}
          </a>
          
          <span class="hidden md:block text-gray-700">|</span>
          
          <a href={siteData.instagram} target="_blank" class="text-brand-gold hover:opacity-80 transition-opacity">
            Instagram
          </a>
          
          <span class="hidden md:block text-gray-700">|</span>
          
          <span class="text-gray-400">Based in IL & IN</span>
        </div>

        <p class="mt-6 font-display text-[11px] tracking-[0.3em] text-gray-600 uppercase">
          © 2026 Ali1_Visuals — All Rights Reserved
        </p>

        <div class="mt-6 mb-0">
          <a 
            href="https://github.com/MuhdTaha" 
            target="_blank" 
            class="group text-[9px] tracking-[0.4em] text-gray-700 uppercase transition-colors hover:text-brand-gold"
          >
            Designed & Developed by <span class="font-bold text-gray-500 group-hover:text-brand-gold">MTAHA</span>
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>